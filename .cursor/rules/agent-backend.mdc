### Реализация handlers (без изменений):

```go
// Issue: #123
package server

import (
    "net/http"
    "github.com/your-org/necpgame/services/{service}-go/pkg/api"
)

type Handlers struct {
    service Service
}

// NewHandlers создает handlers с DI
func NewHandlers(service Service) *Handlers {
    return &Handlers{service: service}
}

// Реализация api.ServerInterface (сгенерированный интерфейс)
func (h *Handlers) ListItems(w http.ResponseWriter, r *http.Request, params api.ListItemsParams) {
    // Используй сгенерированные типы из types.gen.go
    items, err := h.service.ListItems(r.Context(), params)
    if err != nil {
        respondError(w, http.StatusInternalServerError, err.Error())
        return
    }
    
    // Response типы тоже из types.gen.go
    response := api.ListItemsResponse{
        Items: items,
    }
    
    respondJSON(w, http.StatusOK, response)
}
```

