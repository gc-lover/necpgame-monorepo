## Как собирать статистику

### Способ 1: Оптимизированный поиск (рекомендуется)

**ОБЯЗАТЕЛЬНО используй один запрос поиска для всех Issues:**

```javascript
// ✅ ПРАВИЛЬНО: Один запрос для всех Issues с метками агентов
const searchCache = new Map();
const SEARCH_TTL = 2 * 60 * 1000; // 2 минуты

async function collectAllAgentStats() {
  // Один запрос поиска для всех Issues с метками агентов
  const query = 'is:issue label:agent:*';
  const cacheKey = `search:${query}`;
  
  // Проверяем кэш
  if (searchCache.has(cacheKey)) {
    const cached = searchCache.get(cacheKey);
    if (Date.now() - cached.timestamp < SEARCH_TTL) {
      return processStats(cached.data.items);
    }
  }
  
  // Запрашиваем через поиск
  const result = await mcp_github_search_issues({
    query: query,
    perPage: 100
  });
  
  // Кэшируем результаты
  searchCache.set(cacheKey, { data: result, timestamp: Date.now() });
  
  await delay(500);
  
  return processStats(result.items);
}

function processStats(issues) {
  const stats = {};
  const agents = [
    'idea-writer', 'architect', 'api-designer', 'database',
    'backend', 'network', 'devops', 'performance', 'ue5',
    'content-writer', 'qa', 'release', 'security', 'game-balance'
  ];
  
  // Инициализируем статистику для каждого агента
  agents.forEach(agent => {
    stats[agent] = {
      total: 0,
      open: 0,
      closed: 0,
      inProgress: 0,
      returned: 0
    };
  });
  
  // Обрабатываем Issues
  issues.forEach(issue => {
    const agentLabels = issue.labels
      .map(l => l.name)
      .filter(name => name.startsWith('agent:'));
    
    agentLabels.forEach(label => {
      const agent = label.replace('agent:', '');
      if (stats[agent]) {
        stats[agent].total++;
        
        if (issue.state === 'OPEN') {
          stats[agent].open++;
          
          // Проверяем метки для детализации
          if (issue.labels.some(l => l.name === 'returned')) {
            stats[agent].returned++;
          } else {
            stats[agent].inProgress++;
          }
        } else {
          stats[agent].closed++;
        }
      }
    });
  });
  
  return stats;
}
```

### Способ 2: Поиск по каждому агенту (если нужна детализация)

**Если нужна более детальная статистика, используй поиск по каждому агенту с задержками:**

```javascript
// ✅ ПРАВИЛЬНО: Поиск по каждому агенту с задержками и кэшированием
async function collectDetailedStats() {
  const agents = [
    'idea-writer', 'architect', 'api-designer', 'database',
    'backend', 'network', 'devops', 'performance', 'ue5',
    'content-writer', 'qa', 'release', 'security', 'game-balance'
  ];
  
  const stats = {};
  const searchCache = new Map();
  const SEARCH_TTL = 2 * 60 * 1000;
  
  for (const agent of agents) {
    const query = `is:issue label:agent:${agent}`;
    const cacheKey = `search:${query}`;
    
    // Проверяем кэш
    if (searchCache.has(cacheKey)) {
      const cached = searchCache.get(cacheKey);
      if (Date.now() - cached.timestamp < SEARCH_TTL) {
        stats[agent] = processAgentStats(cached.data.items, agent);
        continue;
      }
    }
    
    // Запрашиваем через поиск
    const result = await mcp_github_search_issues({
      query: query,
      perPage: 100
    });
    
    // Кэшируем
    searchCache.set(cacheKey, { data: result, timestamp: Date.now() });
    
    // Обрабатываем статистику
    stats[agent] = processAgentStats(result.items, agent);
    
    // Задержка между запросами
    await delay(500);
  }
  
  return stats;
}
```

